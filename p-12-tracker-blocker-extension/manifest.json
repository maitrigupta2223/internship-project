{
  "manifest_version": 2,
  "name": "Tracker Blocker",
  "version": "1.0",
  "description": "Blocks tracking scripts",

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "storage"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_action": {
    "default_popup": "popup.html"
  }
}
